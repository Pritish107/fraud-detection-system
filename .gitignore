# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Data (too large / private for git)
data/raw/*
data/processed/*
data/interim/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/processed/example_transactions.json
!data/interim/.gitkeep

# Model artifacts (main model + baseline are tracked — small enough for git and
# needed so a fresh clone / CI can run the API, dashboard, and tests without
# retraining or Kaggle credentials)
models/*.pkl
!models/.gitkeep
!models/main_model.txt
!models/main_model_meta.json
!models/baseline_logreg.joblib

# Kaggle credentials
kaggle.json
.kaggle/

# Env / secrets
.env
*.env

# OS / editor
.DS_Store
Thumbs.db
.vscode/settings.json

# Claude Code harness state
.claude/
