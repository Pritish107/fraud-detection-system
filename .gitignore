# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Data (too large / private for git). data/processed/example_transactions.json is the
# one exception — it's FABRICATED data (see src/api/generate_synthetic_examples.py),
# safe to commit and used by the API/dashboard by default. Anything with real
# transaction values (e.g. prepare_examples.py's *_real_LOCAL_ONLY.json output) must
# stay gitignored — IEEE-CIS's competition rules restrict redistributing the dataset
# outside the competition.
data/raw/*
data/processed/*
data/interim/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/processed/example_transactions.json
!data/interim/.gitkeep

# Model artifacts (main model + baseline are tracked — small enough for git and
# needed so a fresh clone / CI can run the API, dashboard, and tests without
# retraining or Kaggle credentials)
models/*.pkl
!models/.gitkeep
!models/main_model.txt
!models/main_model_meta.json
!models/baseline_logreg.joblib

# Kaggle credentials
kaggle.json
.kaggle/

# Env / secrets
.env
*.env

# OS / editor
.DS_Store
Thumbs.db
.vscode/settings.json

# Claude Code harness state
.claude/

# Per-transaction SHAP figures — these bake real feature values from individual
# IEEE-CIS transactions into the image itself (see the data/ note above for why).
# Aggregate figures (shap_summary.png, shap_importance.png) are fine to commit.
reports/figures/shap_local_*.png

# Any file using the _LOCAL_ONLY naming convention (real per-transaction data that must
# never be committed — see prepare_examples.py, generate_shap_report.py) is excluded
# everywhere in the repo, not just in data/, as a defense-in-depth backstop.
**/*_LOCAL_ONLY.*
